<?xml version="1.0" encoding="UTF-8"?>
<!-- BASIC 1: JavaBean data source. Fed by a List<EmployeeReportDto> via JRBeanCollectionDataSource. -->
<!-- Each <field name> must match a bean getter (fullName -> getFullName()). -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
