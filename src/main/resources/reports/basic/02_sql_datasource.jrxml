<?xml version="1.0" encoding="UTF-8"?>
<!-- BASIC 2: SQL data source. JasperReports runs the <queryString> itself against the JDBC Connection. -->
<!-- $P{minUnitPrice} is a query parameter; aliases are quoted so H2 keeps the exact field-name case. -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="02_sql_datasource" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="c0000002-0000-4000-8000-000000000001">
	<parameter name="minUnitPrice" class="java.math.BigDecimal">
		<defaultValueExpression><![CDATA[new java.math.BigDecimal("0")]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT name AS "productName", category AS "category", unit_price AS "unitPrice"
		         FROM product
		         WHERE unit_price >= $P{minUnitPrice}
		         ORDER BY unit_price DESC]]>
	</queryString>
	<field name="productName" class="java.lang.String"/>
	<field name="category" class="java.lang.String"/>
	<field name="unitPrice" class="java.math.BigDecimal"/>
	<variable name="grandTotal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{unitPrice}]]></variableExpression>
	</variable>
	<title>
		<band height="45" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="555" height="26" uuid="c0000002-0000-4000-8000-000000000002"/>
				<textElement textAlignment="Center"><font size="18" isBold="true"/></textElement>
				<textFieldExpression><![CDATA["Products (SQL data source)"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="28" width="555" height="14" uuid="c0000002-0000-4000-8000-000000000003"/>
				<textElement textAlignment="Center"><font size="9" isItalic="true"/></textElement>
				<textFieldExpression><![CDATA["Filter: unit price >= " + $P{minUnitPrice}]]></textFieldExpression>
			</textField>
		</band>
	</title>
	<columnHeader>
		<band height="20" splitType="Stretch">
			<staticText>
				<reportElement mode="Opaque" x="0" y="0" width="300" height="20" forecolor="#FFFFFF" backcolor="#34495E" uuid="c0000002-0000-4000-8000-000000000004"/>
				<box leftPadding="4"/>
				<textElement verticalAlignment="Middle"><font isBold="true"/></textElement>
				<text><![CDATA[Product]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="300" y="0" width="155" height="20" forecolor="#FFFFFF" backcolor="#34495E" uuid="c0000002-0000-4000-8000-000000000005"/>
				<box leftPadding="4"/>
				<textElement verticalAlignment="Middle"><font isBold="true"/></textElement>
				<text><![CDATA[Category]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="455" y="0" width="100" height="20" forecolor="#FFFFFF" backcolor="#34495E" uuid="c0000002-0000-4000-8000-000000000006"/>
				<box rightPadding="4"/>
				<textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true"/></textElement>
				<text><![CDATA[Unit Price]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="18" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="300" height="18" uuid="c0000002-0000-4000-8000-000000000007"/>
				<box leftPadding="4"><bottomPen lineWidth="0.5" lineColor="#DDDDDD"/></box>
				<textFieldExpression><![CDATA[$F{productName}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="300" y="0" width="155" height="18" uuid="c0000002-0000-4000-8000-000000000008"/>
				<box leftPadding="4"><bottomPen lineWidth="0.5" lineColor="#DDDDDD"/></box>
				<textFieldExpression><![CDATA[$F{category}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="455" y="0" width="100" height="18" uuid="c0000002-0000-4000-8000-000000000009"/>
				<box rightPadding="4"><bottomPen lineWidth="0.5" lineColor="#DDDDDD"/></box>
				<textElement textAlignment="Right"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{unitPrice}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<summary>
		<band height="24" splitType="Stretch">
			<staticText>
				<reportElement x="300" y="2" width="155" height="20" uuid="c0000002-0000-4000-8000-00000000000a"/>
				<box rightPadding="4"/>
				<textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true"/></textElement>
				<text><![CDATA[Sum of unit prices]]></text>
			</staticText>
			<textField pattern="#,##0.00">
				<reportElement x="455" y="2" width="100" height="20" uuid="c0000002-0000-4000-8000-00000000000b"/>
				<box rightPadding="4"><topPen lineWidth="1.0"/></box>
				<textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true"/></textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$V{grandTotal}]]></textFieldExpression>
			</textField>
		</band>
	</summary>
</jasperReport>
