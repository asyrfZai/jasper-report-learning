<?xml version="1.0" encoding="UTF-8"?>
<!-- BEGINNER 3: PARAMETERS. Values passed in from Java via the params Map ($P{...}). -->
<!-- Each parameter has a defaultValueExpression, so the report still renders if a value is omitted. -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="03_parameters_greeting" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="b0000003-0000-4000-8000-000000000001">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
	<parameter name="recipientName" class="java.lang.String">
		<defaultValueExpression><![CDATA["Student"]]></defaultValueExpression>
	</parameter>
	<parameter name="courseName" class="java.lang.String">
		<defaultValueExpression><![CDATA["JasperReports"]]></defaultValueExpression>
	</parameter>
	<parameter name="score" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[0]]></defaultValueExpression>
	</parameter>
	<parameter name="generatedOn" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<title>
		<band height="60" splitType="Stretch">
			<textField>
				<reportElement x="0" y="10" width="555" height="35" uuid="b0000003-0000-4000-8000-000000000002"/>
				<textElement textAlignment="Center"><font size="22" isBold="true"/></textElement>
				<textFieldExpression><![CDATA["Hello, " + $P{recipientName} + "!"]]></textFieldExpression>
			</textField>
		</band>
	</title>
	<detail>
		<band height="120" splitType="Stretch">
			<textField>
				<reportElement x="0" y="10" width="555" height="25" uuid="b0000003-0000-4000-8000-000000000003"/>
				<textElement><font size="13"/></textElement>
				<textFieldExpression><![CDATA["You are enrolled in: " + $P{courseName}]]></textFieldExpression>
			</textField>
			<!-- Expressions can do arithmetic and conditionals inline -->
			<textField>
				<reportElement x="0" y="40" width="555" height="25" uuid="b0000003-0000-4000-8000-000000000004"/>
				<textElement><font size="13"/></textElement>
				<textFieldExpression><![CDATA["Your score: " + $P{score} + "/100 (" + ($P{score} >= 60 ? "PASS" : "FAIL") + ")"]]></textFieldExpression>
			</textField>
			<!-- A Date parameter formatted with a pattern -->
			<textField pattern="EEEE, MMMM d, yyyy">
				<reportElement x="0" y="70" width="555" height="25" uuid="b0000003-0000-4000-8000-000000000005"/>
				<textElement><font size="11" isItalic="true"/></textElement>
				<textFieldExpression class="java.util.Date"><![CDATA[$P{generatedOn}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
