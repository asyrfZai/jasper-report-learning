<?xml version="1.0" encoding="UTF-8"?>
<!-- INTERMEDIATE 5: SUBREPORT (master-detail). Master = orders; each order's line items are rendered by -->
<!-- a child report. The child is pre-compiled in Java and handed in as $P{orderItemsSubreport}; -->
<!-- its data comes from dataSourceExpression = a bean data source built from THIS order's $F{items}. -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="05_subreport_master_detail" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="d0000005-0000-4000-8000-000000000001">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
	<parameter name="orderItemsSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
	<field name="orderId" class="java.lang.Long"/>
	<field name="customerName" class="java.lang.String"/>
	<field name="orderDate" class="java.time.LocalDate"/>
	<field name="items" class="java.util.List"/>
	<field name="orderTotal" class="java.math.BigDecimal"/>
	<title>
		<band height="34">
			<staticText>
				<reportElement x="0" y="0" width="555" height="30" uuid="d0000005-0000-4000-8000-000000000002"/>
				<textElement textAlignment="Center"><font size="18" isBold="true"/></textElement>
				<text><![CDATA[Orders with Line Items (subreport)]]></text>
			</staticText>
		</band>
	</title>
	<detail>
		<band height="70">
			<textField>
				<reportElement mode="Opaque" x="0" y="0" width="415" height="20" forecolor="#FFFFFF" backcolor="#16A085" uuid="d0000005-0000-4000-8000-000000000003"/>
				<box leftPadding="6"/><textElement verticalAlignment="Middle"><font size="11" isBold="true"/></textElement>
				<textFieldExpression><![CDATA["Order #" + $F{orderId} + " - " + $F{customerName}]]></textFieldExpression>
			</textField>
			<textField pattern="yyyy-MM-dd">
				<reportElement mode="Opaque" x="415" y="0" width="140" height="20" forecolor="#FFFFFF" backcolor="#16A085" uuid="d0000005-0000-4000-8000-000000000004"/>
				<box rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="10"/></textElement>
				<textFieldExpression class="java.time.LocalDate"><![CDATA[$F{orderDate}]]></textFieldExpression>
			</textField>
			<!-- The subreport. Grows to fit its own content and pushes the band height down. -->
			<subreport>
				<reportElement x="20" y="24" width="515" height="30" uuid="d0000005-0000-4000-8000-000000000005"/>
				<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($F{items})]]></dataSourceExpression>
				<subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{orderItemsSubreport}]]></subreportExpression>
			</subreport>
		</band>
	</detail>
</jasperReport>
