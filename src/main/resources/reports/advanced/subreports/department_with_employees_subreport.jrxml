<?xml version="1.0" encoding="UTF-8"?>
<!-- SUBREPORT (middle level): one row per department, and it ITSELF embeds the employee subreport -->
<!-- passed down as $P{employeeListSubreport}. This is what makes the top-level example "nested". -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="department_with_employees_subreport" pageWidth="515" pageHeight="842" columnWidth="515"
              leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0"
              uuid="e1000002-0000-4000-8000-000000000001">
	<parameter name="employeeListSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
	<field name="name" class="java.lang.String"/>
	<field name="employees" class="java.util.List"/>
	<field name="employeeCount" class="java.lang.Integer"/>
	<field name="totalSalary" class="java.math.BigDecimal"/>
	<detail>
		<band height="40">
			<textField>
				<reportElement mode="Opaque" x="0" y="2" width="515" height="18" forecolor="#FFFFFF" backcolor="#2980B9" uuid="e1000002-0000-4000-8000-000000000002"/>
				<box leftPadding="6"/><textElement verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$F{name} + "   (" + $F{employeeCount} + " staff)"]]></textFieldExpression>
			</textField>
			<!-- nested subreport: the employee list for THIS department -->
			<subreport>
				<reportElement x="0" y="22" width="515" height="15" uuid="e1000002-0000-4000-8000-000000000003"/>
				<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($F{employees})]]></dataSourceExpression>
				<subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{employeeListSubreport}]]></subreportExpression>
			</subreport>
		</band>
	</detail>
</jasperReport>
