<?xml version="1.0" encoding="UTF-8"?>
<!-- SUBREPORT driven by a SQL CONNECTION (not a bean data source). The master passes a live -->
<!-- java.sql.Connection via connectionExpression; JasperReports runs this queryString against it. -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="sales_summary_sql_subreport" pageWidth="515" pageHeight="842" columnWidth="515"
              leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0"
              uuid="e1000004-0000-4000-8000-000000000001">
	<queryString>
		<![CDATA[SELECT p.category AS "category",
		                SUM(oi.quantity) AS "totalQty",
		                SUM(oi.quantity * oi.unit_price) AS "totalSales"
		         FROM order_item oi
		         JOIN product p ON p.id = oi.product_id
		         GROUP BY p.category
		         ORDER BY SUM(oi.quantity * oi.unit_price) DESC]]>
	</queryString>
	<field name="category" class="java.lang.String"/>
	<field name="totalQty" class="java.lang.Long"/>
	<field name="totalSales" class="java.math.BigDecimal"/>
	<columnHeader>
		<band height="18">
			<staticText>
				<reportElement mode="Opaque" x="0" y="0" width="255" height="18" backcolor="#D4E6F1" uuid="e1000004-0000-4000-8000-000000000002"/>
				<box leftPadding="4"/><textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[Category]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="255" y="0" width="120" height="18" backcolor="#D4E6F1" uuid="e1000004-0000-4000-8000-000000000003"/>
				<box rightPadding="4"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[Units Sold]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="375" y="0" width="140" height="18" backcolor="#D4E6F1" uuid="e1000004-0000-4000-8000-000000000004"/>
				<box rightPadding="4"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[Total Sales]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="16">
			<textField>
				<reportElement x="0" y="0" width="255" height="16" uuid="e1000004-0000-4000-8000-000000000005"/>
				<box leftPadding="4"><bottomPen lineWidth="0.5" lineColor="#EEEEEE"/></box>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{category}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="255" y="0" width="120" height="16" uuid="e1000004-0000-4000-8000-000000000006"/>
				<box rightPadding="4"><bottomPen lineWidth="0.5" lineColor="#EEEEEE"/></box>
				<textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression class="java.lang.Long"><![CDATA[$F{totalQty}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="375" y="0" width="140" height="16" uuid="e1000004-0000-4000-8000-000000000007"/>
				<box rightPadding="4"><bottomPen lineWidth="0.5" lineColor="#EEEEEE"/></box>
				<textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{totalSales}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
