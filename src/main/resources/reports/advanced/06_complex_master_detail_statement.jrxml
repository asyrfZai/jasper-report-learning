<?xml version="1.0" encoding="UTF-8"?>
<!-- ADVANCED 6: COMPLEX MASTER-DETAIL. Orders grouped by customer; each order renders its items via a -->
<!-- subreport; each customer group has a subtotal. Rows arrive pre-sorted by customer from the service. -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="06_complex_master_detail_statement" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="f1000006-0000-4000-8000-000000000001">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
	<parameter name="orderItemsSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
	<field name="orderId" class="java.lang.Long"/>
	<field name="customerName" class="java.lang.String"/>
	<field name="orderDate" class="java.time.LocalDate"/>
	<field name="items" class="java.util.List"/>
	<field name="orderTotal" class="java.math.BigDecimal"/>
	<variable name="customerTotal" class="java.math.BigDecimal" calculation="Sum" resetType="Group" resetGroup="customerGroup">
		<variableExpression><![CDATA[$F{orderTotal}]]></variableExpression>
	</variable>
	<variable name="grandTotal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{orderTotal}]]></variableExpression>
	</variable>
	<group name="customerGroup">
		<groupExpression><![CDATA[$F{customerName}]]></groupExpression>
		<groupHeader>
			<band height="26">
				<textField>
					<reportElement mode="Opaque" x="0" y="2" width="555" height="22" forecolor="#FFFFFF" backcolor="#1F618D" uuid="f1000006-0000-4000-8000-000000000002"/>
					<box leftPadding="8"/><textElement verticalAlignment="Middle"><font size="13" isBold="true"/></textElement>
					<textFieldExpression><![CDATA["Statement for " + $F{customerName}]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="26">
				<staticText>
					<reportElement x="295" y="2" width="160" height="20" uuid="f1000006-0000-4000-8000-000000000003"/>
					<box rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true"/></textElement>
					<text><![CDATA[Customer total:]]></text>
				</staticText>
				<textField pattern="#,##0.00">
					<reportElement x="455" y="2" width="100" height="20" forecolor="#1F618D" uuid="f1000006-0000-4000-8000-000000000004"/>
					<box rightPadding="6"><topPen lineWidth="1.0"/></box>
					<textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true"/></textElement>
					<textFieldExpression class="java.math.BigDecimal"><![CDATA[$V{customerTotal}]]></textFieldExpression>
				</textField>
			</band>
		</groupFooter>
	</group>
	<title>
		<band height="34">
			<staticText>
				<reportElement x="0" y="0" width="555" height="30" uuid="f1000006-0000-4000-8000-000000000005"/>
				<textElement textAlignment="Center"><font size="18" isBold="true"/></textElement>
				<text><![CDATA[Customer Statements]]></text>
			</staticText>
		</band>
	</title>
	<detail>
		<band height="60">
			<textField>
				<reportElement x="0" y="2" width="415" height="16" uuid="f1000006-0000-4000-8000-000000000006"/>
				<box leftPadding="6"/><textElement verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<textFieldExpression><![CDATA["Order #" + $F{orderId}]]></textFieldExpression>
			</textField>
			<textField pattern="yyyy-MM-dd">
				<reportElement x="415" y="2" width="140" height="16" uuid="f1000006-0000-4000-8000-000000000007"/>
				<box rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression class="java.time.LocalDate"><![CDATA[$F{orderDate}]]></textFieldExpression>
			</textField>
			<subreport>
				<reportElement x="20" y="20" width="515" height="30" uuid="f1000006-0000-4000-8000-000000000008"/>
				<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($F{items})]]></dataSourceExpression>
				<subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{orderItemsSubreport}]]></subreportExpression>
			</subreport>
		</band>
	</detail>
	<summary>
		<band height="30">
			<staticText>
				<reportElement x="295" y="4" width="160" height="22" uuid="f1000006-0000-4000-8000-000000000009"/>
				<box rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="12" isBold="true"/></textElement>
				<text><![CDATA[GRAND TOTAL:]]></text>
			</staticText>
			<textField pattern="#,##0.00">
				<reportElement x="455" y="4" width="100" height="22" uuid="f1000006-0000-4000-8000-00000000000a"/>
				<box rightPadding="6"><topPen lineWidth="1.5"/></box>
				<textElement textAlignment="Right" verticalAlignment="Middle"><font size="12" isBold="true"/></textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$V{grandTotal}]]></textFieldExpression>
			</textField>
		</band>
	</summary>
</jasperReport>
