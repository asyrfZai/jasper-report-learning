<?xml version="1.0" encoding="UTF-8"?>
<!-- ADVANCED 11: DEEP nested SQL datasets - 5 datasets in one .jrxml. -->
<!--                                                                                                -->
<!-- Section A: 1 AGGREGATE dataset (JOIN + GROUP BY) -> payroll summary per company.               -->
<!-- Section B: 4 datasets nested 4 levels deep, each child query filtered by the parent row's id:   -->
<!--   companyDataset                                                                                -->
<!--     -> departmentDataset   WHERE company_id  = $P{companyId}                                     -->
<!--          -> employeeDataset    WHERE department_id = $P{departmentId} AND salary >= $P{minSalary}-->
<!--               -> salaryHistoryDataset  WHERE employee_id = $P{employeeId}                        -->
<!--                                                                                                -->
<!-- The report parameter $P{minSalary} is THREADED down through every level via <datasetParameter>, -->
<!-- alongside the parent-key parameter. Every dataset runs its own SQL over $P{REPORT_CONNECTION}.  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd"
              name="11_deep_nested_sql_datasets" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              whenNoDataType="AllSectionsNoDetail"
              uuid="f100000b-0000-4000-8000-000000000001">

	<!-- ===== DATASET 1 (aggregate): payroll summary per company (JOIN + GROUP BY) ===== -->
	<subDataset name="payrollSummaryDataset" uuid="f100000b-0000-4000-8000-000000000002">
		<queryString>
			<![CDATA[SELECT c.name AS "companyName",
			                COUNT(e.id) AS "headcount",
			                SUM(e.salary) AS "totalPayroll",
			                AVG(e.salary) AS "avgSalary"
			         FROM company c
			         JOIN department d ON d.company_id = c.id
			         JOIN employee e ON e.department_id = d.id
			         GROUP BY c.name
			         ORDER BY SUM(e.salary) DESC]]>
		</queryString>
		<field name="companyName" class="java.lang.String"/>
		<field name="headcount" class="java.lang.Long"/>
		<field name="totalPayroll" class="java.math.BigDecimal"/>
		<field name="avgSalary" class="java.math.BigDecimal"/>
	</subDataset>

	<!-- ===== DATASET 2: companies (nesting level 1) ===== -->
	<subDataset name="companyDataset" uuid="f100000b-0000-4000-8000-000000000003">
		<parameter name="minSalary" class="java.math.BigDecimal"/>
		<queryString>
			<![CDATA[SELECT id AS "id", name AS "name", founded_year AS "foundedYear" FROM company ORDER BY name]]>
		</queryString>
		<field name="id" class="java.lang.Long"/>
		<field name="name" class="java.lang.String"/>
		<field name="foundedYear" class="java.lang.Integer"/>
	</subDataset>

	<!-- ===== DATASET 3: departments of one company (level 2) ===== -->
	<subDataset name="departmentDataset" uuid="f100000b-0000-4000-8000-000000000004">
		<parameter name="companyId" class="java.lang.Long"/>
		<parameter name="minSalary" class="java.math.BigDecimal"/>
		<queryString>
			<![CDATA[SELECT id AS "id", name AS "name" FROM department
			         WHERE company_id = $P{companyId} ORDER BY name]]>
		</queryString>
		<field name="id" class="java.lang.Long"/>
		<field name="name" class="java.lang.String"/>
	</subDataset>

	<!-- ===== DATASET 4: employees of one department, filtered by threaded minSalary (level 3) ===== -->
	<subDataset name="employeeDataset" uuid="f100000b-0000-4000-8000-000000000005">
		<parameter name="departmentId" class="java.lang.Long"/>
		<parameter name="minSalary" class="java.math.BigDecimal"/>
		<queryString>
			<![CDATA[SELECT id AS "id", first_name AS "firstName", last_name AS "lastName",
			                salary AS "salary", hire_date AS "hireDate"
			         FROM employee
			         WHERE department_id = $P{departmentId} AND salary >= $P{minSalary}
			         ORDER BY salary DESC]]>
		</queryString>
		<field name="id" class="java.lang.Long"/>
		<field name="firstName" class="java.lang.String"/>
		<field name="lastName" class="java.lang.String"/>
		<field name="salary" class="java.math.BigDecimal"/>
		<field name="hireDate" class="java.util.Date"/>
	</subDataset>

	<!-- ===== DATASET 5: salary history of one employee (level 4, deepest) ===== -->
	<subDataset name="salaryHistoryDataset" uuid="f100000b-0000-4000-8000-000000000006">
		<parameter name="employeeId" class="java.lang.Long"/>
		<queryString>
			<![CDATA[SELECT effective_date AS "effectiveDate", amount AS "amount", reason AS "reason"
			         FROM salary_history WHERE employee_id = $P{employeeId} ORDER BY effective_date]]>
		</queryString>
		<field name="effectiveDate" class="java.util.Date"/>
		<field name="amount" class="java.math.BigDecimal"/>
		<field name="reason" class="java.lang.String"/>
	</subDataset>

	<!-- report-level parameter (declared AFTER subDatasets, per JRXML schema order);
	     threaded all the way down to the employee query -->
	<parameter name="minSalary" class="java.math.BigDecimal">
		<defaultValueExpression><![CDATA[new java.math.BigDecimal("0")]]></defaultValueExpression>
	</parameter>

	<title>
		<band height="150" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="0" width="555" height="26" uuid="f100000b-0000-4000-8000-000000000007"/>
				<textElement textAlignment="Center"><font size="18" isBold="true"/></textElement>
				<text><![CDATA[Deep Nested SQL Datasets]]></text>
			</staticText>
			<textField>
				<reportElement x="0" y="28" width="555" height="14" forecolor="#7F8C8D" uuid="f100000b-0000-4000-8000-000000000008"/>
				<textElement textAlignment="Center"><font size="9" isItalic="true"/></textElement>
				<textFieldExpression><![CDATA["5 datasets, 4 levels of nesting - employees filtered to salary >= " + $P{minSalary}]]></textFieldExpression>
			</textField>

			<!-- SECTION A: aggregate dataset (its own JOIN + GROUP BY query) -->
			<staticText>
				<reportElement x="0" y="50" width="555" height="16" forecolor="#1A5276" uuid="f100000b-0000-4000-8000-000000000009"/>
				<textElement><font size="12" isBold="true"/></textElement>
				<text><![CDATA[A. Payroll summary per company]]></text>
			</staticText>
			<componentElement>
				<reportElement x="0" y="68" width="555" height="40" uuid="f100000b-0000-4000-8000-00000000000a"/>
				<jr:list printOrder="Vertical">
					<datasetRun subDataset="payrollSummaryDataset" uuid="f100000b-0000-4000-8000-00000000000b">
						<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
					</datasetRun>
					<jr:listContents height="18" width="555">
						<textField>
							<reportElement x="0" y="0" width="200" height="18" uuid="f100000b-0000-4000-8000-00000000000c"/>
							<box leftPadding="4"><bottomPen lineWidth="0.5" lineColor="#DDDDDD"/></box>
							<textElement verticalAlignment="Middle"><font size="9"/></textElement>
							<textFieldExpression><![CDATA[$F{companyName}]]></textFieldExpression>
						</textField>
						<textField>
							<reportElement x="200" y="0" width="80" height="18" uuid="f100000b-0000-4000-8000-00000000000d"/>
							<box rightPadding="4"><bottomPen lineWidth="0.5" lineColor="#DDDDDD"/></box>
							<textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
							<textFieldExpression class="java.lang.Long"><![CDATA[$F{headcount}]]></textFieldExpression>
						</textField>
						<textField pattern="#,##0.00">
							<reportElement x="280" y="0" width="130" height="18" uuid="f100000b-0000-4000-8000-00000000000e"/>
							<box rightPadding="4"><bottomPen lineWidth="0.5" lineColor="#DDDDDD"/></box>
							<textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
							<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{totalPayroll}]]></textFieldExpression>
						</textField>
						<textField pattern="#,##0.00">
							<reportElement x="410" y="0" width="145" height="18" uuid="f100000b-0000-4000-8000-00000000000f"/>
							<box rightPadding="4"><bottomPen lineWidth="0.5" lineColor="#DDDDDD"/></box>
							<textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
							<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{avgSalary}]]></textFieldExpression>
						</textField>
					</jr:listContents>
				</jr:list>
			</componentElement>
		</band>
	</title>

	<summary>
		<band height="110" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="0" width="555" height="16" forecolor="#1A5276" uuid="f100000b-0000-4000-8000-000000000010"/>
				<textElement><font size="12" isBold="true"/></textElement>
				<text><![CDATA[B. Full drill-down (Company > Department > Employee > Salary History)]]></text>
			</staticText>

			<!-- LEVEL 1: companies -->
			<componentElement>
				<reportElement x="0" y="20" width="555" height="80" uuid="f100000b-0000-4000-8000-000000000011"/>
				<jr:list printOrder="Vertical">
					<datasetRun subDataset="companyDataset" uuid="f100000b-0000-4000-8000-000000000012">
						<datasetParameter name="minSalary">
							<datasetParameterExpression><![CDATA[$P{minSalary}]]></datasetParameterExpression>
						</datasetParameter>
						<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
					</datasetRun>
					<jr:listContents height="60" width="555">
						<textField>
							<reportElement mode="Opaque" x="0" y="2" width="555" height="20" forecolor="#FFFFFF" backcolor="#1A5276" uuid="f100000b-0000-4000-8000-000000000013"/>
							<box leftPadding="8"/><textElement verticalAlignment="Middle"><font size="12" isBold="true"/></textElement>
							<textFieldExpression><![CDATA[$F{name} + "   (founded " + $F{foundedYear} + ")"]]></textFieldExpression>
						</textField>
						<!-- LEVEL 2: departments WHERE company_id = this company's id -->
						<componentElement>
							<reportElement x="10" y="24" width="545" height="34" uuid="f100000b-0000-4000-8000-000000000014"/>
							<jr:list printOrder="Vertical">
								<datasetRun subDataset="departmentDataset" uuid="f100000b-0000-4000-8000-000000000015">
									<datasetParameter name="companyId">
										<datasetParameterExpression><![CDATA[$F{id}]]></datasetParameterExpression>
									</datasetParameter>
									<datasetParameter name="minSalary">
										<datasetParameterExpression><![CDATA[$P{minSalary}]]></datasetParameterExpression>
									</datasetParameter>
									<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
								</datasetRun>
								<jr:listContents height="34" width="545">
									<textField>
										<reportElement mode="Opaque" x="0" y="2" width="545" height="16" forecolor="#FFFFFF" backcolor="#2980B9" uuid="f100000b-0000-4000-8000-000000000016"/>
										<box leftPadding="6"/><textElement verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
										<textFieldExpression><![CDATA["Dept: " + $F{name}]]></textFieldExpression>
									</textField>
									<!-- LEVEL 3: employees WHERE department_id = this dept's id AND salary >= threaded minSalary -->
									<componentElement>
										<reportElement x="14" y="18" width="531" height="14" uuid="f100000b-0000-4000-8000-000000000017"/>
										<jr:list printOrder="Vertical">
											<datasetRun subDataset="employeeDataset" uuid="f100000b-0000-4000-8000-000000000018">
												<datasetParameter name="departmentId">
													<datasetParameterExpression><![CDATA[$F{id}]]></datasetParameterExpression>
												</datasetParameter>
												<datasetParameter name="minSalary">
													<datasetParameterExpression><![CDATA[$P{minSalary}]]></datasetParameterExpression>
												</datasetParameter>
												<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
											</datasetRun>
											<jr:listContents height="28" width="531">
												<textField>
													<reportElement x="0" y="0" width="24" height="14" forecolor="#7F8C8D" uuid="f100000b-0000-4000-8000-000000000019"/>
													<textElement verticalAlignment="Middle"><font size="8"/></textElement>
													<textFieldExpression class="java.lang.Integer"><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
												</textField>
												<textField>
													<reportElement x="24" y="0" width="270" height="14" uuid="f100000b-0000-4000-8000-00000000001a"/>
													<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
													<textFieldExpression><![CDATA[$F{firstName} + " " + $F{lastName}]]></textFieldExpression>
												</textField>
												<textField pattern="yyyy-MM-dd">
													<reportElement x="294" y="0" width="110" height="14" forecolor="#7F8C8D" uuid="f100000b-0000-4000-8000-00000000001b"/>
													<textElement verticalAlignment="Middle"><font size="8"/></textElement>
													<textFieldExpression class="java.util.Date"><![CDATA[$F{hireDate}]]></textFieldExpression>
												</textField>
												<textField pattern="#,##0.00">
													<reportElement x="404" y="0" width="127" height="14" uuid="f100000b-0000-4000-8000-00000000001c"/>
													<textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
													<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{salary}]]></textFieldExpression>
												</textField>
												<!-- LEVEL 4 (deepest): salary history WHERE employee_id = this employee's id -->
												<componentElement>
													<reportElement x="34" y="14" width="497" height="12" uuid="f100000b-0000-4000-8000-00000000001d"/>
													<jr:list printOrder="Vertical">
														<datasetRun subDataset="salaryHistoryDataset" uuid="f100000b-0000-4000-8000-00000000001e">
															<datasetParameter name="employeeId">
																<datasetParameterExpression><![CDATA[$F{id}]]></datasetParameterExpression>
															</datasetParameter>
															<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
														</datasetRun>
														<jr:listContents height="12" width="497">
															<textField pattern="yyyy-MM-dd">
																<reportElement x="0" y="0" width="90" height="12" forecolor="#95A5A6" uuid="f100000b-0000-4000-8000-00000000001f"/>
																<textElement><font size="7"/></textElement>
																<textFieldExpression class="java.util.Date"><![CDATA[$F{effectiveDate}]]></textFieldExpression>
															</textField>
															<textField pattern="#,##0.00">
																<reportElement x="90" y="0" width="90" height="12" forecolor="#95A5A6" uuid="f100000b-0000-4000-8000-000000000020"/>
																<textElement textAlignment="Right"><font size="7"/></textElement>
																<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{amount}]]></textFieldExpression>
															</textField>
															<textField>
																<reportElement x="188" y="0" width="309" height="12" forecolor="#95A5A6" uuid="f100000b-0000-4000-8000-000000000021"/>
																<textElement><font size="7" isItalic="true"/></textElement>
																<textFieldExpression><![CDATA["- " + $F{reason}]]></textFieldExpression>
															</textField>
														</jr:listContents>
													</jr:list>
												</componentElement>
											</jr:listContents>
										</jr:list>
									</componentElement>
								</jr:listContents>
							</jr:list>
						</componentElement>
					</jr:listContents>
				</jr:list>
			</componentElement>
		</band>
	</summary>
</jasperReport>
